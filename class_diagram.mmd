classDiagram
    class Pet {
        +str name
        +str species
        +int age
        +str special_needs
    }

    class Owner {
        +str name
        +int available_time
        +str preferences
        +list pets
    }

    class Task {
        +str name
        +int duration
        +str priority
    }

    class Scheduler {
        +Owner owner
        +list tasks
        +generate_plan() list
    }

    Owner "1" --> "*" Pet : owns
    Owner "1" --> "1" Scheduler : uses
    Scheduler "1" --> "*" Task : schedules
